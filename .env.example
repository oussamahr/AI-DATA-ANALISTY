# =============================================================================
# AI Data Analytics Platform - FastAPI Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- FastAPI Core -----------------------------------------------------------
SECRET_KEY=change-me-to-a-random-secret-key
ENVIRONMENT=development
LOG_LEVEL=INFO
BASE_URL=http://localhost:3000

# --- Database (PostgreSQL) --------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_data

# --- Auth Mode --------------------------------------------------------------
# "local" for built-in JWT/bcrypt auth, "oidc" for delegated OIDC provider
AUTH_MODE=local

# --- OIDC Provider (only used when AUTH_MODE=oidc) -------------------------
# OIDC_ISSUER_URL=https://your-tenant.auth0.com/
# OIDC_AUDIENCE=https://api.yourapp.com
# OIDC_JWKS_URL=https://your-tenant.auth0.com/.well-known/jwks.json
# OIDC_SUBJECT_CLAIM=sub
# OIDC_EMAIL_CLAIM=email
# OIDC_EMAIL_VERIFIED_CLAIM=email_verified
# OIDC_AUTO_PROVISION_USERS=true
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email
# OIDC_ROLES_CLAIM=roles
# OIDC_DEFAULT_ROLE=viewer
# OIDC_ROLE_MAPPING={"admin":"admin","analyst":"analyst","user":"viewer"}

# --- JWT Configuration ------------------------------------------------------
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS -------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Rate Limiting ----------------------------------------------------------
RATE_LIMIT_AUTH_BURST=5/minute
RATE_LIMIT_AUTH_SUSTAINED=20/hour
RATE_LIMIT_USER=100/hour
RATE_LIMIT_TENANT=1000/hour

# --- LLM Provider -----------------------------------------------------------
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-5
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Storage ----------------------------------------------------------------
STORAGE_BACKEND=local
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=[".csv",".tsv",".xlsx",".xls",".json",".parquet",".feather"]

# --- Sentry (optional) ------------------------------------------------------
SENTRY_DSN=

# --- Feature Flags ----------------------------------------------------------
ENABLE_EMAIL_VERIFICATION=True
ENABLE_PII_REDACTION=True
ENABLE_AUDIT_LOGGING=True
ENABLE_STORAGE_QUOTA=True
DEFAULT_STORAGE_QUOTA_MB=1000

# --- Password Policy --------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPER=True
PASSWORD_REQUIRE_LOWER=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True

# --- Token Expiry (hours/days) ----------------------------------------------
VERIFICATION_TOKEN_EXPIRE_HOURS=48
RESET_TOKEN_EXPIRE_HOURS=24
INVITATION_TOKEN_EXPIRE_DAYS=7

# --- SMTP / Email -----------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=AI Data Analytics
SMTP_USE_TLS=True
